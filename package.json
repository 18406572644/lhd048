{
  "name": "pdf-cabinet",
  "version": "1.0.0",
  "description": "极简商务风的本地多 PDF 书签与批注统一管理桌面工具",
  "main": "dist/main/main.js",
  "author": "PDF Cabinet",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "webpack serve --mode development --config webpack.renderer.js",
    "dev:main": "webpack --mode development --config webpack.main.js --watch",
    "dev": "concurrently \"npm:dev:main\" \"npm:dev:renderer\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "webpack --mode production --config webpack.renderer.js",
    "build:main": "webpack --mode production --config webpack.main.js",
    "build": "npm run build:main && npm run build:renderer",
    "start": "cross-env NODE_ENV=production electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "antd": "^5.12.0",
    "better-sqlite3": "^9.2.2",
    "crypto-js": "^4.2.0",
    "docx": "^8.2.4",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.1",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "less": "^4.2.0",
    "less-loader": "^11.1.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.pdfcabinet.app",
    "productName": "PDF Cabinet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
